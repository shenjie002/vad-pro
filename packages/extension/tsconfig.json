{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "lib": [
            "DOM",
            "DOM.Iterable",
            "ESNext"
        ],
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "noEmit": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "jsx": "react-jsx",
        "incremental": true,
        "types": [
            "wxt/client",
            "vite/client"
        ]
    },
    "include": [
        ".wxt/types/*.d.ts",
        "src/**/*",
        "wxt.config.ts"
    ]
}